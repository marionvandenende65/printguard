# PrintGuard — omgevingsvariabelen
# Kopieer naar .env en vul in. Zet .env NOOIT in git.

# Flask
SECRET_KEY=vervang_dit_met_een_lange_willekeurige_string

# Database (pad naar SQLite bestand)
